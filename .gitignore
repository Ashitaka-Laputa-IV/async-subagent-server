# ── Python 字节码 / 缓存 ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── 虚拟环境（uv / venv）────────────────────────────────────────────
.venv/
venv/
env/

# ── 环境变量（含密钥，切勿提交）────────────────────────────────────
.env
.env.*
!.env.example

# ── 测试 / 类型检查 / Linter 缓存 ──────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ── 打包产物 ─────────────────────────────────────────────────────────
*.egg-info/
dist/
build/

# ── 编辑器 / 系统文件 ───────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
